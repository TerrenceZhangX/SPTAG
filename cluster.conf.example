# SPTAG Distributed Benchmark Cluster Configuration
#
# Copy this file to cluster.conf and fill in your machine IPs/paths.
# For 1-node baseline, copy to cluster_1node.conf with a single node entry.
#
# Topology:
#   Node 0 is always the driver + worker0 (run benchmarks from this machine)
#   Node 1..N are remote workers (accessed via SSH)

[cluster]
ssh_user=your_username
sptag_dir=/path/to/SPTAG
data_dir=/path/to/fast/storage
tikv_version=v7.5.1
pd_version=v7.5.1

[nodes]
# host            router_port
# Node 0 (driver, must be current machine)
192.168.1.10       30001
# Node 1 (remote worker)
192.168.1.11       30002

[tikv]
# host            pd_client  pd_peer  tikv_port
192.168.1.10       2379       2380     20161
192.168.1.11       2379       2380     20162
