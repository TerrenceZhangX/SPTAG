graph TB
    subgraph Node0["Compute Node 0 — Driver"]
        BFC["BenchmarkFromConfig<br/>驱动 Insert / Query"]
        ROUTER0["PostingRouter<br/>① GetOwner: 查 PD 做路由决策<br/>② RPC Server: 接收远端请求"]
        OPS0["Append / Split / Merge / Reassign<br/>· Reassign 也经过 Router 路由<br/>· Split/Merge 后异步广播 Head 变更"]
        HEAD0["Head Index 副本<br/>接收其他 Node 的广播更新"]
        VM0["TiKVVersionMap<br/>IncVersion 使用 CAS 保证原子性"]
        BFC --> ROUTER0 --> OPS0
        OPS0 --- HEAD0
        OPS0 --- VM0
    end

    subgraph Node1["Compute Node 1 — Worker"]
        WN1["WorkerNode<br/>RPC Server: 接收 Driver 的 Append"]
        OPS1["Append / Split / Merge / Reassign<br/>· Reassign 也经过 Router 路由<br/>· Split/Merge 后异步广播 Head 变更"]
        HEAD1["Head Index 副本<br/>接收其他 Node 的广播更新"]
        VM1["TiKVVersionMap<br/>IncVersion 使用 CAS 保证原子性"]
        WN1 --> OPS1
        OPS1 --- HEAD1
        OPS1 --- VM1
    end

    subgraph Node2["Compute Node 2 — Worker"]
        WN2["WorkerNode<br/>RPC Server: 接收 Driver 的 Append"]
        OPS2["Append / Split / Merge / Reassign<br/>· Reassign 也经过 Router 路由<br/>· Split/Merge 后异步广播 Head 变更"]
        HEAD2["Head Index 副本<br/>接收其他 Node 的广播更新"]
        VM2["TiKVVersionMap<br/>IncVersion 使用 CAS 保证原子性"]
        WN2 --> OPS2
        OPS2 --- HEAD2
        OPS2 --- VM2
    end

    subgraph Storage["TiKV 集群 — 共享存储"]
        PD["PD (调度中心)<br/>记录每个 key 在哪个 Store"]
        S1["Store 1"]
        S2["Store 2"]
        S3["Store 3"]
    end

    ROUTER0 -->|"isRemote"| WN1
    ROUTER0 -->|"isRemote"| WN2
    ROUTER0 -->|"查 key 归属"| PD
    OPS0 -->|"优先写绑定 Store"| S1
    OPS1 -->|"优先写绑定 Store"| S2
    OPS2 -->|"优先写绑定 Store"| S3

    style Node0 fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    style Node1 fill:#e8f5e9,stroke:#388e3c,stroke-width:2px
    style Node2 fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    style Storage fill:#fce4ec,stroke:#c62828,stroke-width:2px
    style ROUTER0 fill:#fff3cd,stroke:#ffc107
