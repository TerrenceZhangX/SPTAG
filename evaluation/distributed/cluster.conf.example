# SPTAG Distributed Benchmark Cluster Configuration
#
# This file defines the machines, roles, and TiKV topology for
# multi-machine distributed benchmarks.
#
# Usage:
#   cp cluster.conf.example cluster.conf
#   # Edit with your actual IPs and paths
#   ./run_distributed.sh deploy cluster.conf
#   ./run_distributed.sh run cluster.conf 1m
#
# All machines must be reachable via passwordless SSH from the driver.

[cluster]
# SSH user (must have passwordless sudo for docker on all nodes)
ssh_user=zhangt

# SPTAG directory on all nodes (binary + data deployed here)
sptag_dir=/mnt/nvme/SPTAG

# Data directory for index storage (must have sufficient disk space)
data_dir=/mnt/nvme

# TiKV docker image version
tikv_version=v7.5.1

# PD docker image version
pd_version=v7.5.1

[nodes]
# Compute nodes for SPTAG benchmark.
# First node is always the driver (node 0); rest are workers.
# Fields: host  router_port
#
# host          router_port
10.0.1.1        30001
10.0.1.2        30002
10.0.1.3        30003

[tikv]
# TiKV + PD topology. One PD and one TiKV instance per row.
# PD requires at least 1 instance (3 recommended for HA).
# Fields: host  pd_client_port  pd_peer_port  tikv_port
#
# host          pd_client  pd_peer  tikv_port
10.0.1.1        2379       2380     20161
10.0.1.2        2379       2380     20162
10.0.1.3        2379       2380     20163
